# ─────────────────────────────────────────────────────────────────────────────
#  PROJECT TRINITY — Environment Variables
#  Copy this file to `.env.local` and fill in your values.
#  NEVER commit .env.local — it is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
#  Found in: Supabase Dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
# Server-side only — bypasses RLS. Never prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── NOWPayments ──────────────────────────────────────────────────────────────────
#  Found in: NOWPayments Dashboard → Store Settings → API Keys
NOWPAYMENTS_API_KEY=your-nowpayments-api-key-here
# Set to true to use the sandbox API (testing). Remove or set false for production.
NOWPAYMENTS_SANDBOX=false
# Found in: NOWPayments Dashboard → Store Settings → IPN Secret
NOWPAYMENTS_IPN_SECRET=your-ipn-secret-here

# ── Email (Resend) ─────────────────────────────────────────────────────────────────
#  Sign up at https://resend.com — free tier is 100 emails/day, 3,000/month.
#  Found in: Resend Dashboard → API Keys
RESEND_API_KEY=re_your-resend-api-key-here
# The verified sender address in Resend (must match a verified domain).
# For testing before domain verification use: onboarding@resend.dev
EMAIL_FROM=Trinity Trading <noreply@trinitytradingai.com>
EMAIL_REPLY_TO=support@trinitytradingai.com

# ── App ─────────────────────────────────────────────────────────────────────────────
#  Your deployed Vercel URL — used to build success/cancel/IPN callback URLs.
#  For local dev with ngrok: APP_URL=https://xxxx.ngrok-free.app
#  For production: APP_URL=https://trinitytradingai.com
APP_URL=https://trinitytradingai.com

# ── NOWPayments ───────────────────────────────────────────────────────────────
#  Found in: NOWPayments Dashboard → Store Settings → API Keys
#  API key is server-side ONLY — never prefix with VITE_
NOWPAYMENTS_API_KEY=your-api-key-here

#  Set to "true" to route all requests to api.sandbox.nowpayments.io
#  Remove this variable (or set to "false") for production
# NOWPAYMENTS_SANDBOX=true

#  IPN Secret — NOWPayments Dashboard → Store Settings → Instant Payment Notifications
#  Used to verify webhook signatures. Set as soon as possible.
NOWPAYMENTS_IPN_SECRET=your-ipn-secret-here

#  Optional: override the webhook URL (defaults to <your-domain>/api/payments/webhook)
# NOWPAYMENTS_WEBHOOK_URL=https://yourdomain.com/api/payments/webhook
